{
  "name": "hrms-workspace",
  "version": "1.0.0",
  "description": "HRMS Multi-Tenant Monorepo Workspace Root",
  "main": "server/server.js",
  "scripts": {
    "server": "node server/server.js",
    "client": "cd client && npm run dev",
    "build": "npm install && cd client && npm install",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}